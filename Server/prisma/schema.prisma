generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String            @id
  email            String            @unique
  name             String?
  image            String?
  createdAt        DateTime          @default(now())
  workspaceMembers WorkspaceMember[]
  projectMembers   ProjectMember[]
  assignedTasks    Task[]            @relation("TaskAssignee")
  comments         Comment[]
  auditLogs        AuditLog[]
  aiLogs           AILog[]
  aiRecommendations AIRecommendation[]
  ownedProjects    Project[]         @relation("ProjectOwner")
  notifications    Notification[]
  notificationPreferences NotificationPreference?
  workloadAnalyses WorkloadAnalysis[]
}

model Workspace {
  id          String            @id
  name        String
  slug        String            @unique
  description String?
  ownerId     String
  image_url   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  projects    Project[]
  invitations Invitation[]
  auditLogs   AuditLog[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Invitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole    @default(MEMBER)
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([token])
  @@index([workspaceId])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorId     String
  action      String
  targetType  String
  targetId    String?
  targetName  String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User      @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([actorId])
}

model Project {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  priority    Priority        @default(MEDIUM)
  start_date  DateTime?
  end_date    DateTime?
  team_lead   String?
  progress    Int             @default(0)
  isArchived  Boolean         @default(false)
  healthScore Int?            // 0-100, computed on write
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  tasks       Task[]
  owner       User?           @relation("ProjectOwner", fields: [team_lead], references: [id])
  aiLogs      AILog[]
  aiRecommendations AIRecommendation[]
  workloadAnalyses WorkloadAnalysis[]
  riskAssessments RiskAssessment[]

  @@index([workspaceId])
  @@index([status])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id             String        @id @default(cuid())
  projectId      String
  parentId       String?       // subtask parent
  title          String
  description    String?
  status         TaskStatus    @default(TODO)
  type           TaskType      @default(TASK)
  priority       Priority      @default(MEDIUM)
  assigneeId     String?
  due_date       DateTime?
  order          Int           @default(0)  // kanban column order
  estimatedHours Float?
  actualHours    Float?
  isRecurring    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent         Task?         @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks       Task[]        @relation("Subtasks")
  assignee       User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments       Comment[]
  attachments    TaskAttachment[]
  history        TaskHistory[]
  recurringTask  RecurringTask?
  aiLogs         AILog[]
  aiRecommendations AIRecommendation[]
  aiGeneratedTasks AIGeneratedTask[]
  riskAssessments RiskAssessment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([parentId])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  uploadedBy String
  name      String
  url       String
  size      Int?     // bytes
  mimeType  String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskHistory {
  id         String   @id @default(cuid())
  taskId     String
  actorId    String
  field      String   // which field changed
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model RecurringTask {
  id          String   @id @default(cuid())
  taskId      String   @unique
  frequency   RecurringFrequency
  interval    Int      @default(1)  // every N days/weeks/months
  nextDue     DateTime
  lastRun     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([nextDue])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskType {
  TASK
  BUG
  FEATURE
  IMPROVEMENT
  OTHER
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum WorkspaceRole {
  ADMIN
  MANAGER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  PROJECT_UPDATE
  TEAM_MENTION
  DEADLINE_REMINDER
  WORKLOAD_ALERT
  RISK_ALERT
  SYSTEM_NOTIFICATION
}

model AILog {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  projectId   String?
  action      String   // 'generate_subtasks', 'estimate_complexity', 'get_recommendations', etc.
  prompt      String
  response    String?
  tokensUsed  Int?
  cost        Float?
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([projectId])
}

model AIRecommendation {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  projectId   String?
  type        String   // 'subtask_suggestion', 'dependency_suggestion', 'workload_estimate', etc.
  title       String
  description String
  priority    Priority @default(MEDIUM)
  confidence  Float?   // 0-1 confidence score
  metadata    Json?    // additional AI metadata
  isAccepted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([projectId])
  @@index([type])
}

model AIGeneratedTask {
  id             String        @id @default(cuid())
  parentTaskId   String
  title          String
  description    String?
  type           TaskType      @default(TASK)
  priority       Priority      @default(MEDIUM)
  estimatedHours Float?
  sequence       Int           @default(0) // order in the sequence
  dependencies   String[]      // array of task IDs this depends on
  aiMetadata     Json?         // AI generation metadata
  isAccepted     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  parentTask     Task          @relation(fields: [parentTaskId], references: [id], onDelete: Cascade)

  @@index([parentTaskId])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  data        Json?             // additional notification data
  isRead      Boolean           @default(false)
  priority    Priority          @default(MEDIUM)
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  emailEnabled      Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  taskAssigned      Boolean  @default(true)
  taskDue           Boolean  @default(true)
  projectUpdates    Boolean  @default(true)
  teamMentions      Boolean  @default(true)
  deadlineReminders Boolean  @default(true)
  weeklyDigest      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Analytics {
  id          String      @id @default(cuid())
  entityType  String      // 'user', 'project', 'workspace'
  entityId    String
  metric      String      // 'productivity_score', 'completion_rate', 'workload_index', etc.
  value       Float
  period      String      // 'daily', 'weekly', 'monthly'
  periodStart DateTime
  periodEnd   DateTime
  metadata    Json?       // additional analytics data
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([metric, period])
  @@index([periodStart, periodEnd])
}

model WorkloadAnalysis {
  id            String   @id @default(cuid())
  userId        String
  projectId     String?
  workloadScore Float    // 0-100 workload intensity
  capacityScore Float    // 0-100 available capacity
  burnoutRisk   Float    // 0-100 risk percentage
  recommendations Json?  // AI-generated recommendations
  analyzedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([analyzedAt])
}

model RiskAssessment {
  id              String   @id @default(cuid())
  projectId       String
  taskId          String?
  riskType        String   // 'delay', 'overdue', 'resource', 'dependency'
  riskScore       Float    // 0-100 risk level
  impactScore     Float    // 0-100 potential impact
  probability     Float    // 0-100 likelihood
  description     String
  mitigationSteps Json?    // suggested mitigation actions
  status          String   @default("active") // 'active', 'mitigated', 'resolved'
  assessedAt      DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([taskId])
  @@index([riskType])
}
